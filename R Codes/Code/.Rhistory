T_rep <- sqrt(n) * (W_hat - W_true) / sd_hat
df <- rF0(n)
df$D <- rbinom(n, 1, spec$p0(df$X1, df$X2))
df$Y <- spec$mu0(df$X1, df$X2, df$D) + rnorm(n, 0, spec$noise_sd)
#### First stage
# (1) estimate p₀(x) using all obs.
ps_mod   <- bam(D ~ te(X1, X2),
data = df,
family = binomial(),
method = "fREML",
discrete = TRUE)
# (2) estimate μ₀(x,0) using control units
ctrl_mod <- bam(Y ~ te(X1, X2),
data = df,
subset = (D == 0),
family = gaussian(),
method = "fREML",
discrete = TRUE)
# (3)estimate μ₀(x,1) using treated units
trt_mod  <- bam(Y ~ te(X1, X2),
data = df,
subset = (D == 1),
family = gaussian(),
method = "fREML",
discrete = TRUE)
# Second stage. Estimate W̄(μ₀) using plug-ins form first stage
X_int    <- spec$rF(10000)
mu1_int  <- predict(trt_mod, newdata = X_int, type = "response")
mu0_int  <- predict(ctrl_mod, newdata = X_int, type = "response")
W_hat    <- mean(pmax(mu1_int - mu0_int, 0), na.rm = TRUE)
#### Compute sd of W̄̂(μ̂₀)
p_hat    <- predict(ps_mod, newdata = df, type = "response")
mu0_hat  <- predict(ctrl_mod, newdata = df, type = "response")
mu1_hat  <- predict(trt_mod, newdata = df, type = "response")
# (1) compute the indicator I(μ₀(x,1) − μ₀(x,0))
ind      <- as.numeric((mu1_hat - mu0_hat) >= 0)
# (2) estimate σ²(x)
resid    <- ifelse(df$D == 1, df$Y - mu1_hat, df$Y - mu0_hat)
sig2_mod <- gam(I(resid^2) ~ te(X1,X2), data = df, family = gaussian(), method = "REML")
sig2_hat <- predict(sig2_mod, newdata = df, type = "response")
# (3) compute λ(x)²
lambda2  <- (spec$fF(df$X1, df$X2))^2
# (4) sd
sd_hat   <- sqrt(mean(ind * lambda2 * sig2_hat / (p_hat * (1 - p_hat))/n, na.rm = TRUE))
sd_hat
W_hat
X_true <- spec$rF(2e5)
W_true <- mean(pmax(spec$mu0(X_true$X1, X_true$X2, 1) - spec$mu0(X_true$X1, X_true$X2, 0), 0))
