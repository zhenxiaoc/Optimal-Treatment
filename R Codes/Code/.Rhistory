rF0 <- function(n) data.frame(X1 = runif(n), X2 = runif(n))               # Measure F_0 of obs. Assumed to be uniform for X1 and X2
specs <- list(
#### Model 1
list(
name = "Beta(2,5), Beta(5,2)",
rF   = function(m) data.frame(X1 = rbeta(m,2,5), X2 = rbeta(m,5,2)),  # Measure F of target pop.
fF   = function(x1,x2) dbeta(x1,5,2) * dbeta(x2,5,2),                 # Density f of target pop.
p0   = function(x1,x2) plogis(x1 - x2),                               # Propensity score fun.
mu0  = function(x1,x2,d) sin(2*pi*x1)*cos(2*pi*x2) + d*(0.2 + x1^2 - x2),   # Regression fun.
noise_sd = 0.5                                                        # Noise level in regression
)
)
df <- rF0(n)
n <- 1000
df <- rF0(n)
df$D <- rbinom(n, 1, spec$p0(df$X1, df$X2))
spec<-   list(
name = "Beta(2,5), Beta(5,2)",
rF   = function(m) data.frame(X1 = rbeta(m,2,5), X2 = rbeta(m,5,2)),  # Measure F of target pop.
fF   = function(x1,x2) dbeta(x1,5,2) * dbeta(x2,5,2),                 # Density f of target pop.
p0   = function(x1,x2) plogis(x1 - x2),                               # Propensity score fun.
mu0  = function(x1,x2,d) sin(2*pi*x1)*cos(2*pi*x2) + d*(0.2 + x1^2 - x2),   # Regression fun.
noise_sd = 0.5                                                        # Noise level in regression
)
df <- rF0(n)
df$D <- rbinom(n, 1, spec$p0(df$X1, df$X2))
df$Y <- spec$mu0(df$X1, df$X2, df$D) + rnorm(n, 0, spec$noise_sd)
#### First stage
# (1) estimate p₀(x) using all obs.
ps_mod   <- bam(D ~ te(X1, X2),
data = df,
family = binomial(),
method = "fREML",
discrete = TRUE)
# (2) estimate μ₀(x,0) using control units
ctrl_mod <- bam(Y ~ te(X1, X2),
data = df,
subset = (D == 0),
family = gaussian(),
method = "fREML",
discrete = TRUE)
# (3)estimate μ₀(x,1) using treated units
trt_mod  <- bam(Y ~ te(X1, X2),
data = df,
subset = (D == 1),
