),
list(
name = "Beta(5,2)",
rF   = function(m) data.frame(X = rbeta(m,5,2)),
fF   = function(x) dbeta(x,5,2),
p0   = function(x) plogis(-0.5 + x),
mu0  = function(x,d) 0.5*sqrt(x) + d*(0.5 - x^2),
noise_sd = 0.5
),
list(
name = "Uniform",
rF   = function(m) data.frame(X = rbeta(m,1,1)),
fF   = function(x) dbeta(x,1,1),
p0   = function(x) plogis(0.5 - x),
mu0  = function(x,d) x^2 + d*(1 - x),
noise_sd = 0.5
)
)
ite <- 1000                 # number of iterations
ns <- c(100, 400, 1600)     # sample sizes
plan(multisession, workers = parallel::detectCores() - 1)
set.seed(2025)
results <- lapply(specs, function(spec) {
# Approximate the parameter of interest
X_true <- spec$rF(2e5)
W_true <- mean(pmax(spec$mu0(X_true$X, 1) - spec$mu0(X_true$X, 0), 0))
# Run 1000 iterations for different sample sizes
do.call(rbind, lapply(ns, function(n) {
hats <- future_replicate(ite, one_ite(spec, n), future.seed = TRUE)
W_hat <- hats["W_hat" , ]
sd_hat <- hats["sd_hat", ]
cover <- (W_hat - 1.96*sd_hat <= W_true)*(W_hat + 1.96*sd_hat >= W_true)
data.frame(
spec      = spec$name,
n         = n,
bias      = mean(W_hat - W_true),
variance  = var(W_hat),
coverage  = mean(cover)
)
}))
})
final_df <- do.call(rbind, results)
rownames(final_df) <- NULL
print(final_df)
